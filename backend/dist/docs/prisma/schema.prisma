generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                Role
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
}

model Vehicle {
  id                String            @id @default(uuid())
  regNo             String            @unique
  name              String
  type              String
  maxLoadCapacityKg Float
  odometer          Float             @default(0)
  acquisitionCost   Float
  revenue           Float             @default(0)
  region            String?
  status            VehicleStatus     @default(AVAILABLE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  trips             Trip[]
  maintenanceLogs   MaintenanceRecord[]
  fuelLogs          FuelLog[]
  expenses          Expense[]

  @@index([status])
  @@index([type])
  @@index([region])
}

model Driver {
  id               String       @id @default(uuid())
  name             String
  licenseNumber    String       @unique
  licenseCategory  String
  licenseExpiry    DateTime
  contact          String
  safetyScore      Float        @default(100)
  tripCompletionPct Float       @default(0)
  status           DriverStatus @default(AVAILABLE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  trips            Trip[]

  @@index([status])
  @@index([licenseCategory])
}

model Trip {
  id                String     @id @default(uuid())
  source            String
  destination       String
  vehicleId         String
  driverId          String
  cargoWeightKg     Float
  plannedDistanceKm Float
  finalOdometer     Float?
  fuelConsumedL     Float?
  status            TripStatus @default(DRAFT)
  cancellationReason String?
  createdAt         DateTime   @default(now())
  dispatchedAt      DateTime?
  completedAt       DateTime?
  vehicle           Vehicle    @relation(fields: [vehicleId], references: [id])
  driver            Driver     @relation(fields: [driverId], references: [id])
  fuelLogs          FuelLog[]
  expenses          Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceRecord {
  id          String            @id @default(uuid())
  vehicleId   String
  serviceType String
  cost        Float
  date        DateTime
  status      MaintenanceStatus @default(ACTIVE)
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  expenses    Expense[]

  @@index([vehicleId])
  @@index([status])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  date      DateTime
  liters    Float
  cost      Float
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([date])
}

model Expense {
  id                  String             @id @default(uuid())
  tripId              String?
  vehicleId           String
  toll                Float              @default(0)
  other               Float              @default(0)
  linkedMaintenanceId String?
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id])
  trip                Trip?              @relation(fields: [tripId], references: [id])
  linkedMaintenance   MaintenanceRecord? @relation(fields: [linkedMaintenanceId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
}

model Settings {
  id           String  @id @default("singleton")
  depotName    String  @default("TransitOps HQ")
  currency     String  @default("INR")
  distanceUnit String  @default("km")
  ratePerKm    Float   @default(10)
}
